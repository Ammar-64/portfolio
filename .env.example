# Contact form (Resend) — copy to .env and fill in.
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional. Inbox that receives contact-form messages.
# Defaults to ammar.n.sammour@gmail.com if unset.
CONTACT_TO_EMAIL=

# Optional. Sender address — must be on a domain verified in Resend
# (https://resend.com/domains). Until you verify one, leave this unset and
# Resend's shared onboarding@resend.dev sender is used (delivers only to the
# email of your own Resend account).
CONTACT_FROM_EMAIL=
